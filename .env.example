# SQLAlchemy database URL (optional). Default: sqlite file under data/db/
# DATABASE_URL=sqlite:////app/data/db/grillkit.db

# Hugging Face token for Whisper/Piper downloads (optional).
# HF_TOKEN=

# Linux bind-mount ownership for ./data (optional).
# PUID=1000
# PGID=1000

# Coding section (optional). Requires Judge0 when enabled.
# CODING_ENABLED=true
# JUDGE0_URL=http://localhost:2358
# JUDGE0_AUTH_TOKEN=
